<!DOCTYPE html>
<html lang="<%= getLocale() %>" data-bs-theme="dark">
<head>
    <%- include('partials/head') %>
</head>
<body class="bg-dark text-light d-flex flex-column min-vh-100">
    
    <%- include('partials/navbar') %>

    <div class="container flex-grow-1" style="max-width: 900px;">
        <div class="card bg-secondary text-light shadow-lg mb-4 mt-3">
            <div class="card-body">
                <div class="position-relative">
                    <input type="text" id="searchInput" class="form-control bg-dark text-light border-secondary form-control-lg shadow-sm" placeholder="<%= __('searchPlaceholder') %>" autocomplete="off">
                    <ul id="suggestionList" class="list-group position-absolute w-100 mt-1 shadow-lg" style="z-index: 1000; display: none; max-height: 250px; overflow-y: auto;"></ul>
                </div>
            </div>
        </div>

        <form action="/calculate" method="GET" id="calcForm">
            <input type="hidden" name="lang" value="<%= getLocale() %>">
            <div id="championCardsContainer" class="row g-3 mb-4"></div>
            <button type="submit" id="calculateBtn" class="btn btn-success w-100 fw-bold fs-5 shadow" style="display: none;"><%= __('calculateBtn') %></button>
        </form>
    </div>

    <%- include('partials/footer') %>

    <script id="champData" type="application/json">
        <%- JSON.stringify(champions) %>
    </script>

    <script>
        const patchVersion = "<%= version %>";

        const searchInput = document.getElementById('searchInput');
        const suggestionList = document.getElementById('suggestionList');
        const container = document.getElementById('championCardsContainer');
        const calculateBtn = document.getElementById('calculateBtn');
        const calcForm = document.getElementById('calcForm');

        const textHaste = "<%= __('abilityHaste') %>";
        const textDelete = "<%= __('delete') %>";

        let championsData = [];
        try {
            championsData = JSON.parse(document.getElementById('champData').textContent);
        } catch (e) {
            console.error("Şampiyon verisi okunamadı!", e);
        }

        const normalize = (str) => str.toLowerCase().replace(/[^a-z0-9]/g, '');

        searchInput.addEventListener('input', (e) => {
            const val = normalize(e.target.value);
            suggestionList.innerHTML = '';
            if (!val) { suggestionList.style.display = 'none'; return; }

            const matches = championsData.filter(c =>
                normalize(c.name).includes(val) || normalize(c.id).includes(val)
            );

            matches.forEach(m => {
                const li = document.createElement('li');
                li.className = 'list-group-item list-group-item-dark list-group-item-action d-flex align-items-center';
                li.style.cursor = 'pointer';
                li.innerHTML = `
                    <img src="https://ddragon.leagueoflegends.com/cdn/${patchVersion}/img/champion/${m.id}.png" class="rounded-circle me-3 shadow-sm" style="width:32px; height:32px;">
                    <span class="fw-bold text-warning">${m.name}</span>
                `;
                li.onclick = () => selectChampion(m);
                suggestionList.appendChild(li);
            });
            suggestionList.style.display = matches.length > 0 ? 'block' : 'none';
        });

        searchInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                const val = normalize(searchInput.value);
                if (!val) {
                    if (container.children.length > 0) calcForm.submit();
                    return;
                }
                const firstMatch = championsData.find(c =>
                    normalize(c.name).includes(val) || normalize(c.id).includes(val)
                );
                if (firstMatch) selectChampion(firstMatch);
            }
        });

        function selectChampion(champ) {
            addChampionCard(champ);
            searchInput.value = '';
            suggestionList.style.display = 'none';
            calculateBtn.style.display = 'block';
        }

        function addChampionCard(champ) {
            if (document.getElementById(`card-${champ.id}`)) return;

            const col = document.createElement('div');
            col.className = 'col-md-6';
            col.id = `card-${champ.id}`;

            col.innerHTML = `
                <div class="card bg-dark border-secondary shadow">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <img src="https://ddragon.leagueoflegends.com/cdn/${patchVersion}/img/champion/${champ.id}.png" class="rounded-circle me-3 border border-warning shadow-sm" style="width: 48px; height: 48px;">
                            <div>
                                <h5 class="card-title text-warning mb-1">${champ.name}</h5>
                                <input type="hidden" name="champions" value="${champ.id}">
                                <div class="input-group input-group-sm mt-2" style="width: 170px;">
                                    <span class="input-group-text bg-secondary text-light border-secondary shadow-sm">${textHaste}</span>
                                    <input type="number" class="form-control bg-dark text-light border-secondary haste-input shadow-sm" name="haste_${champ.id}" value="0" min="0">
                                </div>
                            </div>
                        </div>
                        <button type="button" class="btn btn-outline-danger btn-sm shadow-sm" onclick="removeCard('${champ.id}')">${textDelete}</button>
                    </div>
                </div>
            `;
            container.appendChild(col);

            setTimeout(() => {
                const newHasteInput = col.querySelector('.haste-input');
                newHasteInput.select();
                newHasteInput.addEventListener('keydown', (evt) => {
                    if (evt.key === 'Enter') {
                        evt.preventDefault();
                        searchInput.focus();
                    }
                });
            }, 50);
        }

        window.removeCard = function(champId) {
            const card = document.getElementById(`card-${champId}`);
            if (card) card.remove();
            if (container.children.length === 0) calculateBtn.style.display = 'none';
        };

        document.addEventListener('click', (e) => {
            if (e.target !== searchInput) suggestionList.style.display = 'none';
        });
    </script>
</body>
</html>