<nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary mb-4 shadow-sm">
    <div class="container" style="max-width: 1200px;">
        <a class="navbar-brand text-warning fw-bold d-flex align-items-center" href="/?lang=<%= getLocale() %>">
            <img src="https://ddragon.leagueoflegends.com/cdn/14.5.1/img/item/3158.png" alt="Logo" width="30" height="30" class="rounded-circle me-2">
            <%= __('title') %>
        </a>

        <div class="d-flex align-items-center">
            <button onclick="changeLanguage('tr')" class="btn btn-sm <%= getLocale() === 'tr' ? 'btn-warning fw-bold' : 'btn-outline-secondary' %> me-2 shadow-sm">TR</button>
            <button onclick="changeLanguage('en')" class="btn btn-sm <%= getLocale() === 'en' ? 'btn-warning fw-bold' : 'btn-outline-secondary' %> shadow-sm">EN</button>
        </div>
    </div>
</nav>

<script>
    function changeLanguage(lang) {
        const url = new URL(window.location.href);
        url.searchParams.set('lang', lang);
        window.location.href = url.toString();
    }
</script>